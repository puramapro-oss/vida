{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "thinking": {
    "enabled": true,
    "budget": 10000
  },
  "outputStyle": "explanatory",
  "autoCompact": true,
  "env": {
    "MAX_THINKING_TOKENS": "10000"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "cat ~/purama/LEARNINGS.md 2>/dev/null | tail -20 || true",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "command": "echo $CLAUDE_FILE_PATH | grep -qE '\\.(env|lock)$' && echo 'BLOCKED: .env or .lock file' && exit 1 || exit 0",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "command": "npx prettier --write $CLAUDE_FILE_PATH 2>/dev/null || true",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "grep -rn 'TODO\\|console\\.log\\|placeholder\\|any:\\|Lorem\\|t\u00e9moignage' src/ 2>/dev/null | head -10 && echo '\u26d4 PLACEHOLDERS OR FAKE CONTENT \u2014 FIX' && exit 2 || echo '\u2705 Clean'",
            "type": "command"
          }
        ]
      }
    ]
  }
}